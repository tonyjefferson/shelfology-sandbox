<!-- ============================================================
     BACK TO TOP WIDGET
     Paste once per page, near the bottom of content.
     ============================================================ -->

<button
  id="shlf-btt"
  onclick="shlfScrollToTop();"
  aria-label="Back to top"
  title="Back to top"
  style="
    position: fixed;
    bottom: 2em;
    left: 50%;
    transform: translateX(-50%) translateY(12px);
    z-index: 9999;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: #67AFCE;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 16px rgba(103,175,206,0.35);
    opacity: 0;
    transition: opacity 0.3s ease, transform 0.3s ease, background 0.2s ease;
    pointer-events: none;
  "
  onmouseover="this.style.background='#54737B';"
  onmouseout="this.style.background='#67AFCE';">

  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#FFFDFB" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M12 19V5M5 12l7-7 7 7"/>
  </svg>

</button>

<script>
(function() {
  var btn = document.getElementById('shlf-btt');
  var THRESHOLD = 400;

  function getScrollTop() {
    return window.pageYOffset || document.documentElement.scrollTop || document.body.scrollTop || 0;
  }

  function updateBtn() {
    if (!btn) return;
    if (getScrollTop() > THRESHOLD) {
      btn.style.opacity = '1';
      btn.style.transform = 'translateX(-50%) translateY(0)';
      btn.style.pointerEvents = 'auto';
    } else {
      btn.style.opacity = '0';
      btn.style.transform = 'translateX(-50%) translateY(12px)';
      btn.style.pointerEvents = 'none';
    }
  }

  window.shlfScrollToTop = function() {
    try {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    } catch (e) {
      window.scrollTo(0, 0);
    }
  };

  if (window.addEventListener) {
    window.addEventListener('scroll', updateBtn, { passive: true });
  } else if (window.attachEvent) {
    window.attachEvent('onscroll', updateBtn);
  }

  updateBtn();
})();
</script>


