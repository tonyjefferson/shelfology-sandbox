    var btn = document.getElementById('shlf-video-btn');
    var play = document.getElementById('shlf-icon-play');
    var pause = document.getElementById('shlf-icon-pause');

    if (!video || !btn || !play || !pause) return;

    if (video.paused) {
      var promise = video.play();
      if (promise && typeof promise.then === 'function') {
        promise.then(function() {
          play.style.display = 'none';
          pause.style.display = 'block';
          btn.setAttribute('aria-label', 'Pause video');
