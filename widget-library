<script>
(function() {
  var links = document.querySelectorAll('.shlf-toc-link');
  var anchors = [];
  var i;

  function smoothScrollToTarget(target) {
    if (!target) return;
    if (target.scrollIntoView) {
      try {
        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
        return;
      } catch (e) {}
    }
    var top = target.getBoundingClientRect().top + (window.pageYOffset || document.documentElement.scrollTop || 0);
    window.scrollTo(0, top);
  }

  for (i = 0; i < links.length; i++) {
    (function(link) {
      link.addEventListener('click', function(e) {
        var href = this.getAttribute('href');
        var id = href ? href.replace('#', '') : '';
        var target = document.getElementById(id);
        if (target) {
          e.preventDefault();
          smoothScrollToTarget(target);
        }
      });
    })(links[i]);
  }

  for (i = 0; i < links.length; i++) {
    var href = links[i].getAttribute('href');
    var id = href ? href.replace('#', '') : '';
    var el = document.getElementById(id);
    if (el) anchors.push({ el: el, link: links[i] });
  }

  if ('IntersectionObserver' in window && anchors.length) {
    var active = null;
    var observer = new IntersectionObserver(function(entries) {
      var j, k, match;
      for (j = 0; j < entries.length; j++) {
        if (entries[j].isIntersecting) {
          if (active) {
            active.style.color = '#67AFCE';
            active.style.fontWeight = '500';
            if (active.parentElement) active.parentElement.style.paddingLeft = '1em';
          }
          match = null;
          for (k = 0; k < anchors.length; k++) {
            if (anchors[k].el === entries[j].target) {
              match = anchors[k];
              break;
            }
          }
          if (match) {
            active = match.link;
            active.style.color = '#54737B';
            active.style.fontWeight = '700';
            if (active.parentElement) active.parentElement.style.paddingLeft = '1.35em';
          }
        }
      }
    }, { rootMargin: '0px 0px -60% 0px', threshold: 0 });

    for (i = 0; i < anchors.length; i++) {
      observer.observe(anchors[i].el);
    }
  }
})();
</script>


