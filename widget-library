<script>
(function() {
  function shlfGetDrawers() {
    return document.querySelectorAll('.shlf-drawer');
  }

  function shlfEachDrawer(callback) {
    var drawers = shlfGetDrawers();
    var i;
    for (i = 0; i < drawers.length; i++) {
      callback(drawers[i]);
    }
  }

  function shlfLockScroll(lock) {
    var html = document.documentElement;
    var body = document.body;
    if (lock) {
      html.style.overflow = 'hidden';
      body.style.overflow = 'hidden';
    } else {
      html.style.overflow = '';
      body.style.overflow = '';
    }
  }

  function shlfHideDrawer(drawer) {
    if (!drawer) return;
    if (drawer._shlfTimer) clearTimeout(drawer._shlfTimer);
    drawer.style.transform = 'translateX(100%)';
    drawer.setAttribute('aria-hidden', 'true');
    drawer._shlfTimer = setTimeout(function() {
      drawer.style.display = 'none';
    }, 300);
  }

  window.shlfOpen = function(id) {
    var overlay = document.getElementById('shlf-overlay');
    var drawer = document.getElementById(id);

    shlfEachDrawer(function(d) {
      if (d._shlfTimer) clearTimeout(d._shlfTimer);
      d.style.display = 'none';
      d.style.transform = 'translateX(100%)';
      d.setAttribute('aria-hidden', 'true');
    });

    if (!drawer || !overlay) return;

    drawer.style.display = 'flex';
    drawer.setAttribute('aria-hidden', 'false');
    overlay.style.display = 'block';
    overlay.setAttribute('aria-hidden', 'false');
    shlfLockScroll(true);

    setTimeout(function() {
      drawer.style.transform = 'translateX(0)';
    }, 20);
  };

  window.shlfClose = function(id) {
    var drawer = document.getElementById(id);
    var overlay = document.getElementById('shlf-overlay');

    if (!drawer) return;

    shlfHideDrawer(drawer);

    setTimeout(function() {
      var anyOpen = false;
      shlfEachDrawer(function(d) {
        if (d.style.display !== 'none') anyOpen = true;
      });
      if (!anyOpen && overlay) {
        overlay.style.display = 'none';
        overlay.setAttribute('aria-hidden', 'true');
        shlfLockScroll(false);
      }
    }, 300);
  };

  window.shlfCloseAll = function() {
    var overlay = document.getElementById('shlf-overlay');

    shlfEachDrawer(function(d) {
      shlfHideDrawer(d);
    });

    setTimeout(function() {
      if (overlay) {
        overlay.style.display = 'none';
        overlay.setAttribute('aria-hidden', 'true');
      }
      shlfLockScroll(false);
    }, 300);
  };

  document.addEventListener('keydown', function(e) {
    e = e || window.event;
    var key = e.key || e.keyCode;
    if (key === 'Escape' || key === 'Esc' || key === 27) {
      window.shlfCloseAll();
    }
  });
})();
</script>

